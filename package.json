{
  "name": "gff-nostream",
  "version": "3.0.2",
  "description": "utilities to read GFF3 data",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmdcolin/gff-nostream.git"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "import": "./esm/index.js"
    },
    "require": {
      "require": "./dist/index.js"
    }
  },
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com",
    "url": "https://github.com/cmdcolin"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "benchonly": "vitest bench",
    "bench": "./scripts/build-both-branches.sh \"$BRANCH1\" \"$BRANCH2\" && vitest bench",
    "clean": "rimraf dist esm",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "docs": "documentation readme src/api.ts --section=API  --shallow && yarn format",
    "format": "prettier --write .",
    "prebuild": "yarn clean",
    "build:esm": "tsc --target esnext --outDir esm",
    "build:es5": "tsc --target es2020 --module commonjs --moduleResolution bundler --outDir dist",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "build": "yarn build:es5 && yarn build:esm",
    "prepublishOnly": "yarn test --run && yarn build",
    "postversion": "git push --follow-tags"
  },
  "keywords": [
    "bionode",
    "biojs",
    "gff3",
    "gff",
    "genomics"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "documentation": "^14.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@jbrowse/quick-lru": "^7.3.5"
  }
}
